{
  "expo": {
    "name": "Nano",
    "slug": "Nano",
    "scheme": "nano",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.samabidoye.Nano"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.samabidoye.Nano"
    },
    "web": {
      "favicon": ""
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ]
  }
}
